generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  login     String   @unique
  password  String
  name      String?
  role           String   @default("OWNER")
  specialization String?
  centerId       Int?
  center    Center?  @relation(fields: [centerId], references: [id])
  payments  Payment[]
  createdAt DateTime @default(now())
}
model Center {
  id        Int       @id @default(autoincrement())
  name      String
  login     String    @unique
  password  String
  status    String    @default("Active")
  botToken  String?
  eskizEmail String?
  eskizPassword String?
  smsEnabled Boolean?   @default(false)
  createdAt DateTime  @default(now())
  users     User[]
  courses   Course[]
  groups    Group[]
  payments  Payment[]
  students  Student[]
  leads     Lead[]
  attendance Attendance[]
  absenceRequests AbsenceRequest[]
}

model Course {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  duration    Int       @default(1)
  price       Float
  centerId    Int
  createdAt   DateTime  @default(now())
  center      Center    @relation(fields: [centerId], references: [id])
  groups      Group[]
  payments    Payment[]
  students    Student[]
  leads       Lead[]
}

model Group {
  id        Int       @id @default(autoincrement())
  name      String
  teacher   String?
  days      String?
  time      String?
  centerId  Int
  courseId  Int
  createdAt DateTime  @default(now())
  course    Course    @relation(fields: [courseId], references: [id])
  center      Center       @relation(fields: [centerId], references: [id])
  students    Student[]
  attendance  Attendance[]
}

model Student {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String
  address   String?
  dob       String?
  status    String    @default("Active")
  telegramId String?   @unique
  parentTelegramId String? @unique
  parentPhone String?
  centerId  Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  payments  Payment[]
  courses   Course[]
  groups    Group[]
  attendance Attendance[]
  absenceRequests AbsenceRequest[]
  center    Center    @relation(fields: [centerId], references: [id])
}

model Payment {
  id          Int      @id @default(autoincrement())
  amount      Float
  studentId   Int
  courseId    Int
  centerId    Int
  paymentDate DateTime @default(now())
  paidUntil   DateTime?
  paymentType String   @default("CASH")
  periodFrom  DateTime?
  periodTo    DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  center      Center   @relation(fields: [centerId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
}

model Attendance {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  status      String   @default("PRESENT") // PRESENT, ABSENT, EXCUSED
  studentId   Int
  groupId     Int
  centerId    Int
  createdAt   DateTime @default(now())
  
  student     Student  @relation(fields: [studentId], references: [id])
  group       Group    @relation(fields: [groupId], references: [id])
  center      Center   @relation(fields: [centerId], references: [id])
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  source    String?  // Instagram, Telegram, Recommendation, etc.
  status    String   @default("New") // New, RECONTACT, INFO_GIVEN, Trial, Student, Rejected
  notes     String?
  callbackAt DateTime? // Reminder date/time
  centerId  Int
  courseId  Int?     // Interested in which course?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  center    Center   @relation(fields: [centerId], references: [id])
  course    Course?  @relation(fields: [courseId], references: [id])
}

model AbsenceRequest {
  id        Int      @id @default(autoincrement())
  studentId Int
  centerId  Int
  date      DateTime @default(now())
  reason    String?
  createdAt DateTime @default(now())
  
  student   Student  @relation(fields: [studentId], references: [id])
  center    Center   @relation(fields: [centerId], references: [id])
}
